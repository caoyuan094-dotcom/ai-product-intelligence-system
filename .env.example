# Server-side provider keys. Set these in Vercel Project Settings -> Environment Variables.
OPENAI_API_KEY="sk-..."
OPENAI_TEXT_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"

GEMINI_API_KEY="AIza..."
GEMINI_TEXT_MODEL="gemini-3-flash-preview"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"

# OpenAI-compatible provider example: DeepSeek, OpenRouter, Groq, SiliconFlow, etc.
COMPATIBLE_PROVIDER_LABEL="DeepSeek"
COMPATIBLE_BASE_URL="https://api.deepseek.com/v1"
COMPATIBLE_API_KEY="sk-..."
COMPATIBLE_TEXT_MODEL="deepseek-chat"
COMPATIBLE_SUPPORTS_IMAGES="false"

# Advanced: override all providers with JSON.
# AI_PROVIDERS='[{"id":"openai","label":"OpenAI","type":"openai","apiKeyEnv":"OPENAI_API_KEY","baseUrl":"https://api.openai.com/v1","defaultTextModel":"gpt-4.1-mini","defaultImageModel":"gpt-image-1","supportsImages":true}]'
